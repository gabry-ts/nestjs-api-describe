{
  "name": "nestjs-api-describe",
  "version": "1.0.0",
  "description": "Composite decorators for standardizing OpenAPI documentation and input validation in NestJS APIs",
  "author": "Gabriele Partiti",
  "license": "MIT",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "nestjs",
    "decorator",
    "openapi",
    "swagger",
    "validation",
    "class-validator",
    "dto"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/gabry-ts/nestjs-api-describe"
  },
  "scripts": {
    "build": "tsup",
    "lint": "eslint 'src/**/*.ts'",
    "format": "prettier --write 'src/**/*.ts'",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:cov": "jest --coverage",
    "prepare": "husky"
  },
  "peerDependencies": {
    "@nestjs/common": ">=10",
    "@nestjs/swagger": ">=7",
    "class-transformer": ">=0.5",
    "class-validator": ">=0.14",
    "reflect-metadata": ">=0.1"
  },
  "devDependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/swagger": "^7.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/jest": "^29.5.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "eslint": "^8.57.0",
    "husky": "^9.0.0",
    "jest": "^29.7.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "ts-jest": "^29.1.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
